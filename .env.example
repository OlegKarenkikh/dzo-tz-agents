# ── LLM ─────────────────────────────────────────────────────
# API ключ (для локальных моделей можно оставить пустым — пропишется "ollama")
OPENAI_API_KEY=sk-...

# Модель. Примеры:
#   gpt-4o, gpt-4o-mini         (OpenAI)
#   deepseek-chat               (DeepSeek)
#   llama3, mistral, qwen2.5    (Ollama — имя модели из ollama list)
#   microsoft/phi-4             (vLLM / LM Studio)
MODEL_NAME=gpt-4o

# Эндпоинт LLM (оставить пустым → api.openai.com/v1)
#   http://localhost:11434/v1          (Ollama)
#   http://localhost:1234/v1           (LM Studio)
#   https://api.deepseek.com/v1        (DeepSeek)
#   https://<resource>.openai.azure.com/ (Azure OpenAI)
#   http://localhost:8000/v1           (vLLM / LocalAI)
OPENAI_API_BASE=

# Режим агента:
#   openai_tools  — быстрый native function-calling
#                   (для GPT-4o, GPT-4-turbo, DeepSeek-V3+, Qwen2.5-72B+ с tool-support)
#   react         — ReAct prompting, работает с любой моделью
#                   (для Ollama llama3/mistral, локальных LLM без function-calling)
AGENT_TYPE=openai_tools

# ── Режим агентов ─────────────────────────────────────────────
AGENT_MODE=both                   # dzo | tz | both
POLL_INTERVAL_SEC=300

# ── IMAP — Агент ДЗО ─────────────────────────────────────────
DZO_IMAP_HOST=imap.example.com
DZO_IMAP_PORT=993
DZO_IMAP_USER=dzo@example.com
DZO_IMAP_PASSWORD=
DZO_IMAP_FOLDER=INBOX

# ── IMAP — Агент ТЗ ──────────────────────────────────────────
TZ_IMAP_HOST=imap.example.com
TZ_IMAP_PORT=993
TZ_IMAP_USER=tz@example.com
TZ_IMAP_PASSWORD=
TZ_IMAP_FOLDER=INBOX

# ── SMTP ───────────────────────────────────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=agent@example.com
SMTP_PASSWORD=

# ── Email руководителя ─────────────────────────────────────────
MANAGER_EMAIL=manager@example.com

# ── Telegram ───────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── PostgreSQL ───────────────────────────────────────────────
POSTGRES_DB=dzo_agents
POSTGRES_USER=dzo
POSTGRES_PASSWORD=change-me-strong-password   # ОБЯЗАТЕЛЬНО изменить!
DATABASE_URL=postgresql://dzo:change-me-strong-password@postgres:5432/dzo_agents

# ── REST API ─────────────────────────────────────────────────
API_KEY=change-me-strong-api-key              # ОБЯЗАТЕЛЬНО изменить!

# ── Web UI ───────────────────────────────────────────────────
UI_API_URL=http://localhost:8000
UI_API_KEY=change-me-strong-api-key
