# OpenAI
OPENAI_API_KEY=sk-...

# SMTP (общий)
SMTP_HOST=mail.company.ru
SMTP_PORT=587
SMTP_USER=ucz@company.ru
SMTP_PASSWORD=secret

# Общее
MANAGER_EMAIL=manager@company.ru

# IMAP — Агент ДЗО
DZO_IMAP_HOST=mail.company.ru
DZO_IMAP_USER=ucz-zayavki@company.ru
DZO_IMAP_PASSWORD=secret1
DZO_SMTP_FROM=ucz-zayavki@company.ru

# IMAP — Агент ТЗ
TZ_IMAP_HOST=mail.company.ru
TZ_IMAP_USER=ucz-tz@company.ru
TZ_IMAP_PASSWORD=secret2
TZ_SMTP_FROM=ucz-tz@company.ru

# Telegram (опционально)
TELEGRAM_BOT_TOKEN=123456:ABC-...
TELEGRAM_CHAT_ID=-100123456789

# Режим запуска: dzo | tz | both
AGENT_MODE=both

# Интервал опроса в секундах (по умолчанию 300 = 5 мин)
POLL_INTERVAL_SEC=300

# Модель OpenAI
MODEL_NAME=gpt-4o
