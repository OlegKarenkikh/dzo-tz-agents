# =============================================================================
# Агенты ДЗО/ТЗ — пример конфигурации .env
# Скопируйте этот файл в .env и заполните своими значениями
# =============================================================================

# ⚠️  ВНИМАНИЕ для GitHub Codespaces пользователей:
#   - Не заполняйте OPENAI_API_KEY и LLM_BACKEND
#   - Конфигурация АВТОМАТИЧЕСКИ переключится на LLM_BACKEND=github_models
#   - Будет использован GITHUB_TOKEN (предоставляется автоматически)

# -----------------------------------------------------------------------------
# LLM — выберите один из разделов ниже
# -----------------------------------------------------------------------------

# ☁️  OpenAI (по умолчанию)
OPENAI_API_KEY=sk-...
MODEL_NAME=gpt-4o
OPENAI_API_BASE=
AGENT_TYPE=openai_tools
LLM_BACKEND=openai

# 🦙  Ollama (локально)
# MODEL_NAME=qwen2.5
# OPENAI_API_BASE=http://localhost:11434/v1
# AGENT_TYPE=react
# LLM_BACKEND=ollama

# 🌊  DeepSeek
# OPENAI_API_KEY=sk-...
# MODEL_NAME=deepseek-chat
# OPENAI_API_BASE=https://api.deepseek.com/v1
# AGENT_TYPE=openai_tools
# LLM_BACKEND=deepseek

# ⚡  vLLM
# MODEL_NAME=Qwen/Qwen2.5-72B-Instruct
# OPENAI_API_BASE=http://localhost:8000/v1
# AGENT_TYPE=openai_tools
# LLM_BACKEND=vllm

# 🏠  LM Studio
# MODEL_NAME=local-model
# OPENAI_API_BASE=http://localhost:1234/v1
# AGENT_TYPE=openai_tools
# LLM_BACKEND=lmstudio

# 🐙  GitHub Models
# Используйте GitHub Personal Access Token (PAT) в качестве OPENAI_API_KEY,
# либо не задавайте OPENAI_API_KEY вовсе — тогда будет автоматически
# использован GITHUB_TOKEN из окружения (GitHub Actions / Copilot Workspace /
# Codespaces предоставляют его без дополнительной настройки).
# Токен: https://github.com/settings/tokens (scope: read:user достаточно)
# ❗ OPENAI_API_BASE игнорируется при LLM_BACKEND=github_models —
#    endpoint зашит в коде: https://models.inference.ai.azure.com
# OPENAI_API_KEY=ghp_...     ← или оставьте пустым: подхватится GITHUB_TOKEN
# MODEL_NAME=gpt-4o
# AGENT_TYPE=openai_tools
# LLM_BACKEND=github_models

# -----------------------------------------------------------------------------
# Обсервабильность — Langfuse (визуализация флоу агента)
# -----------------------------------------------------------------------------

# Оставьте пустыми — трейсинг выключен (без ошибок)
# Для активации укажите ключи проекта из https://cloud.langfuse.com или self-hosted установки
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
# LANGFUSE_HOST=http://localhost:3000   ← для self-hosted, по умолчанию https://cloud.langfuse.com

# -----------------------------------------------------------------------------
# Fallback-модели (автопереключение при 429/413)
# -----------------------------------------------------------------------------

# Для github_models: встроенная цепочка работает автоматически.
# Для ollama/vllm/lmstudio: доступные модели обнаруживаются через API.
# Здесь можно задать ЯВНЫЙ порядок fallback для любого бэкенда (через запятую):
# FALLBACK_MODELS=qwen2.5,llama3.1,mistral

# -----------------------------------------------------------------------------
# Режим агентов
# -----------------------------------------------------------------------------

# Какие агенты запускать: both | dzo | tz
AGENT_MODE=both

# Интервал опроса почты (IMAP), секунды
POLL_INTERVAL_SEC=300

# Email для эскалаций
MANAGER_EMAIL=manager@company.ru

# Обходить дедупликацию (только для отладки)
FORCE_REPROCESS=false

# -----------------------------------------------------------------------------
# REST API (FastAPI backend)
# -----------------------------------------------------------------------------

# Ключ доступа к API
API_KEY=change-me-strong-api-key

# -----------------------------------------------------------------------------
# Streamlit UI
# -----------------------------------------------------------------------------

# URL бэкенда (FastAPI)
UI_API_URL=http://localhost:8000

# Ключ для обращения из UI к API (обычно совпадает с API_KEY)
UI_API_KEY=change-me-strong-api-key

# Интервал авто-обновления дашборда (секунды)
UI_AUTO_REFRESH_SEC=30

# -----------------------------------------------------------------------------
# Почта (IMAP/SMTP)
# -----------------------------------------------------------------------------

IMAP_HOST=imap.company.ru
IMAP_PORT=993
IMAP_USER=agent@company.ru
IMAP_PASSWORD=secret
IMAP_FOLDER=INBOX

SMTP_HOST=smtp.company.ru
SMTP_PORT=587
SMTP_USER=agent@company.ru
SMTP_PASSWORD=secret
SMTP_FROM=agent@company.ru
